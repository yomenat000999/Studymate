{
  "version": 2,
  "functions": {
    "api/chat.js": { "memory": 256, "maxDuration": 30 },
    "api/parse.js": { "memory": 256, "maxDuration": 30 },
    "api/transcribe.js": { "memory": 256, "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
